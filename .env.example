APP_SECRET=change-this-long-random-secret

# Preferred: individual friend accounts.
TRAINER_USERS=[{"id":"you","name":"You","password":"change-me","role":"admin"},{"id":"friend","name":"Friend","password":"change-me-too","role":"member"}]

# Optional Vercel KV / Upstash REST storage for synced progress on Vercel.
KV_REST_API_URL=https://your-kv-url.upstash.io
KV_REST_API_TOKEN=your-kv-token
# Or use the Upstash Redis names if the integration creates those instead:
UPSTASH_REDIS_REST_URL=https://your-kv-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-kv-token

DOCSDOCS_USER=your-docsdocs-username
DOCSDOCS_PASSWORD=your-docsdocs-password
